{
  "buildCommand": null,
  "devCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "routes": [
    { "src": "/api/search", "dest": "/api/search.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "functions": {
    "api/search.py": {
      "runtime": "python3.11",
      "maxDuration": 10
    }
  }
}
